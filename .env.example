# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/atomquest?retryWrites=true&w=majority

# URLs (Update to your production domain when deployed)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Cloudinary (File Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# MediaSoup SFU WebRTC Configuration
# Local testing: MEDIASOUP_LISTEN_IP=127.0.0.1 or your local LAN IP (e.g., 192.168.1.5)
# Production server (AWS/DigitalOcean): MEDIASOUP_LISTEN_IP=0.0.0.0 and MEDIASOUP_ANNOUNCED_IP=<Server Public IP>
MEDIASOUP_LISTEN_IP=127.0.0.1
MEDIASOUP_ANNOUNCED_IP=
